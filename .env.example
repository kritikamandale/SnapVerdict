# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.
#
# ── Gemini API Keys ──────────────────────────────────────────────────────────
# Up to 10 Gemini API keys are supported for project-aware round-robin rotation.
# Keys 1-6 belong to GCP project gen-lang-client-0765394622 (gemini-2.5-flash).
# Keys 7,10 belong to GCP project rankproject-502415 (gemini-2.0-flash).
# Keys 8,9 belong to GCP project ambient-sphere-502415-a7 (gemini-2.0-flash).
# At least one key is required. Set only the ones you have.
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_API_KEY_3=your_gemini_api_key_3_here
GEMINI_API_KEY_4=your_gemini_api_key_4_here
GEMINI_API_KEY_5=your_gemini_api_key_5_here
GEMINI_API_KEY_6=your_gemini_api_key_6_here
GEMINI_API_KEY_7=your_gemini_api_key_7_here
GEMINI_API_KEY_8=your_gemini_api_key_8_here
GEMINI_API_KEY_9=your_gemini_api_key_9_here
GEMINI_API_KEY_10=your_gemini_api_key_10_here

# ── Backend (Render) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (e.g. your Vercel URL).
# Use * for local dev or to allow all origins during demo.
ALLOWED_ORIGIN=*

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
# Set this in Vercel project env vars to point at the live Render backend URL.
# For local dev, Vite falls back to http://127.0.0.1:8000.
VITE_API_BASE_URL=http://127.0.0.1:8000
